# Supabase — proyecto creado en https://supabase.com/dashboard
# Copiá estos valores desde Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role: SOLO server-side. Nunca exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=

# URL pública de la landing (sin slash final). Ej: https://sekura.com.ar
# En dev: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# URL de la plataforma Sekura Monitoreo. Default apunta al prototipo embebido
# en /public/monitoreo/. El día que la plataforma viva en su propio dominio,
# cambiar a algo tipo: https://app.sekura.com.ar
# IMPORTANTE: si el valor contiene un "#", encerrarlo entre comillas dobles —
# si no, dotenv lo lee como inicio de comentario y se trunca.
NEXT_PUBLIC_PLATFORM_URL="/monitoreo/index.html#BR/scanner/MT-5108402-A1B2C3D4E5F6789012345678ABCDEF01"
